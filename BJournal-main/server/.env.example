# ─── BJournal & The Fools Hunting Room Cloud Backend Setup ───

# PORT for online hosting (Render.com automatically sets PORT)
PORT=3001

# MongoDB Atlas Database Connection URL (Leave empty for local file storage fallback `data/db.json`)
# Example: mongodb+srv://username:password@cluster0.mongodb.net/bjournal?retryWrites=true&w=majority
MONGODB_URI=

# Finnhub API Key for live Forex News & Economic Calendar (Free key: https://finnhub.io/register)
FINNHUB_API_KEY=

# Gmail SMTP Credentials for auto-email sending & weekly trading reports
# Note: Use a Google App Password (not your main Gmail account password)
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Cron Schedule for automated weekly reports (Default: 0 9 * * 1 = Every Monday at 9:00 AM)
REPORT_SCHEDULE="0 9 * * 1"
REPORT_RECIPIENTS="trader1@example.com,trader2@example.com"
